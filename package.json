{
  "name": "whatsapp-sales-backend",
  "version": "7.0.0",
  "description": "Hidata v20 — WhatsApp-native Sales Operating System for LATAM edtech",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "prisma generate && node --import ./instrument.mjs src/server.js",
    "test": "node --test",
    "build": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@google/genai": "^2.8.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.58.0",
    "@upstash/redis": "^1.34.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
