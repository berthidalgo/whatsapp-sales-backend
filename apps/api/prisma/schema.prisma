generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════
// MOTOR v19 — Modelos legacy (intactos durante migración)
// ════════════════════════════════════════════════════════

// ─── Vendedores ───────────────────────────────────────────────
model Vendor {
  id                 Int                @id @default(autoincrement())
  tenantId           String             @default("peru_exporta") @map("tenant_id")
  nombre             String
  telefono           String             @unique
  role               String             @default("VENDOR")
  activo             Boolean            @default(true)
  instanciaEvolution String?
  whatsappNumber     String?            @unique
  pin                String?            @default("0000")
  campaigns          Campaign[]
  leads              Lead[]
  conversations      Conversation[]
  leadStates         LeadState[]
  callEvents         CallEvent[]
  crmNotifications   CrmNotification[]
  archivedLeads      Lead[]             @relation("LeadArchivedBy")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([tenantId])
  @@map("vendors")
}

// ─── Campañas ─────────────────────────────────────────────────
model Campaign {
  id            Int            @id @default(autoincrement())
  tenantId      String         @default("peru_exporta") @map("tenant_id")
  slug          String         @unique
  nombre        String
  activa        Boolean        @default(true)
  vendorId      Int
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  triggers      Trigger[]
  steps         FlowStep[]
  leads         Lead[]
  conversations Conversation[]
  botPrompt     String?        @db.Text

  // ── Config declarativa del agente (Sprint 2) ──
  // La "pizarra" editable por el usuario desde su dashboard:
  // factSheet (precio/incluye/NO_incluye), agentGoal, autonomyLevel,
  // persona del agente, circuitBreaker, handoff, extras de atribución.
  // Los triggers y steps siguen como tablas (se editan pieza por pieza).
  config        Json?

  version       Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId])
  @@map("campaigns")
}

// ─── Triggers ─────────────────────────────────────────────────
model Trigger {
  id         Int      @id @default(autoincrement())
  texto      String
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("triggers")
}

// ─── Pasos del flujo ──────────────────────────────────────────
model FlowStep {
  id          Int      @id @default(autoincrement())
  orden       Int
  tipo        String   // MSG | FOLLOWUP | NOTIFY
  mensaje     String   @db.Text
  followupHrs Int?
  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, orden])
  @@map("flow_steps")
}

// ─── Leads ────────────────────────────────────────────────────
model Lead {
  id                Int                 @id @default(autoincrement())
  tenantId          String              @default("peru_exporta") @map("tenant_id")
  telefono          String
  campaignId        Int?
  campaign          Campaign?           @relation(fields: [campaignId], references: [id])
  vendorId          Int?
  vendor            Vendor?             @relation(fields: [vendorId], references: [id])
  pasoActual        Int                 @default(0)
  ultimoMensaje     DateTime?
  notificado        Boolean             @default(false)
  estado            String              @default("NUEVO")
  nombreDetectado   String?
  productoDetectado String?

  // ── Direccionamiento WhatsApp (Sprint 2 — soporte @lid) ──
  // waJid: JID real al que responder (PN preferido, @lid como fallback).
  // addressingMode: 'pn' | 'lid' | 'lid_unrecovered' | 'unknown'.
  waJid             String?             @map("wa_jid")
  addressingMode    String?             @map("addressing_mode")
  
  // Soft delete fields (v20)
  archivedAt        DateTime?           @map("archived_at")
  archivedReason    String?             @map("archived_reason")
  archivedById      Int?                @map("archived_by")
  archivedBy        Vendor?             @relation("LeadArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  
  mensajes          Message[]
  conversations     Conversation[]
  leadState         LeadState?
  turnTraces        TurnTrace[]
  callEvents        CallEvent[]
  commitments       Commitment[]
  followupQueue     FollowupQueueItem[]
  crmNotifications  CrmNotification[]
  mediaAssets       MediaAsset[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Multitenancy: el teléfono es único POR TENANT, no global.
  // Evita que un mismo número robe el lead de un tenant a otro.
  @@unique([tenantId, telefono])
  @@index([tenantId])
  @@map("leads")
}

// ─── Conversaciones (fuente de verdad del bot v19) ────────────
model Conversation {
  id                      Int           @id @default(autoincrement())
  leadId                  Int
  lead                    Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId              Int?
  campaign                Campaign?     @relation(fields: [campaignId], references: [id])
  vendorId                Int?
  vendor                  Vendor?       @relation(fields: [vendorId], references: [id])
  state                   String        @default("ACTIVE")
  currentStep             Int           @default(0)
  lastBotMessageAt        DateTime?
  lastLeadMessageAt       DateTime?
  reactivationCount       Int           @default(0)
  lastReactivationAt      DateTime?
  vendorNotifiedAt        DateTime?
  vendorNotificationCount Int           @default(0)
  reminderJobId           String?
  messages                Message[]
  turnTraces              TurnTrace[]
  createdAt               DateTime      @default(now())

  @@unique([leadId, campaignId])
  @@map("conversations")
}

// ─── Historial de mensajes ────────────────────────────────────
model Message {
  id             Int           @id @default(autoincrement())
  leadId         Int
  lead           Lead          @relation(fields: [leadId], references: [id])
  conversationId Int?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  origen         String        // LEAD | BOT | VENDEDOR
  texto          String        @db.Text
  createdAt      DateTime      @default(now())

  @@map("messages")
}

// ─── Media entrante (comprobantes, fotos del lead) ────────────
// El lead manda una imagen por WhatsApp → el cerebro la baja para que Gemini la
// lea, y AHORA además la persistimos para mostrarla en el Inbox. `storage` es la
// costura: hoy 'pg' (bytes en la BD, servidos por endpoint propio con JWT → cero
// URL pública = no fuga de PII financiera del comprobante). Migrable a 'supabase'
// (bucket privado + signed URLs) si el volumen crece. `messageId` linkea al mensaje
// marcador del timeline. NO se relaciona a Message (tabla caliente) → Int suelto.
model MediaAsset {
  id          Int      @id @default(autoincrement())
  leadId      Int      @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messageId   Int?     @map("message_id")
  tenantId    String?  @map("tenant_id")
  origen      String   @default("LEAD")            // LEAD | VENDEDOR
  tipo        String                                // image | audio
  mimeType    String   @map("mime_type")
  storage     String   @default("pg")              // pg | supabase
  bytes       Bytes?                                // si storage=pg
  url         String?                               // si storage=supabase
  sizeBytes   Int?     @map("size_bytes")
  createdAt   DateTime @default(now())             @map("created_at")

  @@index([leadId])
  @@map("media_assets")
}

// ─── Configuración del bot ────────────────────────────────────
model BotConfig {
  id              String   @id
  tenantId        String   @default("hidata")
  activo          Boolean  @default(true)
  nombre          String?
  msgBienvenida   String?  @db.Text
  msgProducto     String?  @db.Text
  msgExperiencia  String?  @db.Text
  msgPresentacion String?  @db.Text
  msgObjecion     String?  @db.Text
  msgUrgencia     String?  @db.Text
  msgHandoff      String?  @db.Text
  nombreEmpresa   String?
  nombreProducto  String?
  updatedEn       DateTime @default(now())

  @@map("bot_config")
}

// ════════════════════════════════════════════════════════
// MOTOR v20 — Nueva arquitectura conversacional
// 4 capas: Perception, State, Policy, Response
// ════════════════════════════════════════════════════════

// ─── Estado conversacional vivo ───────────────────────────────
model LeadState {
  leadId             Int      @id @map("lead_id")
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  currentMode        String   @default("AUTO_CONSULTIVO") @map("current_mode")
  currentStage       String   @default("greeting")        @map("current_stage")
  slotsFilled        Json     @default("{}")              @map("slots_filled")
  slotsPending       String[] @default([])                @map("slots_pending")
  intentosPorSlot    Json     @default("{}")              @map("intentos_por_slot")
  
  vendorActiveId     Int?                                 @map("vendor_active_id")
  vendor             Vendor?  @relation(fields: [vendorActiveId], references: [id], onDelete: SetNull)
  
  modeEnteredAt      DateTime @default(now())             @map("mode_entered_at")
  lastMessageAt      DateTime @default(now())             @map("last_message_at")
  returningLeadFlag  Boolean  @default(false)             @map("returning_lead_flag")

  // Etiqueta MANUAL del vendedor (CRM), distinta de la temperatura que detecta el
  // cerebro. Columna propia (no en slots_filled) → inmune al upsert del bot. Texto
  // libre en la BD; la taxonomía válida la fija la capa app (inbox-actions).
  label              String?                              @map("label")
  
  createdAt          DateTime @default(now())             @map("created_at")
  updatedAt          DateTime @default(now())             @updatedAt @map("updated_at")

  @@map("lead_state")
}

// ─── Trace inmutable de cada turno conversacional ─────────────
model TurnTrace {
  turnId               String        @id @default(uuid()) @map("turn_id")
  
  leadId               Int?          @map("lead_id")
  lead                 Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadIdArchived       Int?          @map("lead_id_archived")
  
  conversationId       Int?          @map("conversation_id")
  conversation         Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  
  resetGeneration      Int           @default(1) @map("reset_generation")
  dataQuality          String        @default("real_pilot") @map("data_quality")
  
  leadMessage          String        @db.Text @map("lead_message")
  leadMessageType      String        @default("text") @map("lead_message_type")
  
  perception           Json          @default("{}")
  perceptionVersion    String?       @map("perception_version")
  
  stateBefore          Json          @default("{}") @map("state_before")
  stateAfter           Json          @default("{}") @map("state_after")
  
  modeRouterDecision   Json          @default("{}") @map("mode_router_decision")
  
  policyDecision       Json          @default("{}") @map("policy_decision")
  policyVersion        String?       @map("policy_version")
  guardrailsEvaluated  String[]      @default([])  @map("guardrails_evaluated")
  
  botResponse          String?       @db.Text @map("bot_response")
  responseVersion      String?       @map("response_version")
  
  modelUsed            String?       @map("model_used")
  
  auditLog             Json          @default("{}") @map("audit_log")
  errors               Json          @default("[]")
  
  latencyMs            Int?          @map("latency_ms")
  modelCosts           Json          @default("{}") @map("model_costs")
  
  piiRedactedAt        DateTime?     @map("pii_redacted_at")
  
  createdAt            DateTime      @default(now()) @map("created_at")

  @@map("turn_trace")
}

// ─── Eventos de llamada con outcome tagging ───────────────────
model CallEvent {
  id                    String       @id @default(uuid())
  leadId                Int          @map("lead_id")
  lead                  Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vendorId              Int          @map("vendor_id")
  vendor                Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  scheduledAt           DateTime?    @map("scheduled_at")
  occurredAt            DateTime?    @map("occurred_at")
  durationSeconds       Int?         @map("duration_seconds")
  
  outcomeTag            String?      @map("outcome_tag")
  modalidadAcordada     String?      @map("modalidad_acordada")
  fechaProximoEvento    DateTime?    @map("fecha_proximo_evento")
  condicionesEspeciales String?      @db.Text @map("condiciones_especiales")
  vendorNotes           String?      @db.Text @map("vendor_notes")
  voiceNoteUrl          String?      @map("voice_note_url")
  
  commitments           Commitment[]
  
  createdAt             DateTime     @default(now()) @map("created_at")

  @@map("call_events")
}

// ─── Compromisos extraídos ────────────────────────────────────
model Commitment {
  id               String     @id @default(uuid())
  leadId           Int        @map("lead_id")
  lead             Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  callEventId      String?    @map("call_event_id")
  callEvent        CallEvent? @relation(fields: [callEventId], references: [id], onDelete: SetNull)
  
  description      String     @db.Text
  dueDate          DateTime   @map("due_date")
  fulfilled        Boolean    @default(false)
  fulfilledAt      DateTime?  @map("fulfilled_at")
  
  reminderSent     Boolean    @default(false) @map("reminder_sent")
  reminderSentAt   DateTime?  @map("reminder_sent_at")
  
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at")

  @@map("commitments")
}

// ─── Cola de followup automático ──────────────────────────────
model FollowupQueueItem {
  id               String    @id @default(uuid())
  leadId           Int       @map("lead_id")
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  scheduledFor     DateTime  @map("scheduled_for")
  contextSnapshot  Json      @default("{}") @map("context_snapshot")
  followupType     String    @default("soft_reengagement") @map("followup_type")
  
  executed         Boolean   @default(false)
  executedAt       DateTime? @map("executed_at")
  result           String?   @db.Text
  
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("followup_queue")
}

// ─── Notificaciones priorizadas para CRM ──────────────────────
model CrmNotification {
  id               String    @id @default(uuid())
  vendorId         Int       @map("vendor_id")
  vendor           Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  leadId           Int?      @map("lead_id")
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  priority         String
  title            String
  message          String    @db.Text
  payload          Json      @default("{}")
  
  acknowledged     Boolean   @default(false)
  acknowledgedAt   DateTime? @map("acknowledged_at")
  
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("crm_notifications")
}

// ─── Lista de teléfonos de prueba ─────────────────────────────
model TestPhone {
  telefono     String   @id
  addedAt      DateTime @default(now()) @map("added_at")
  addedBy      String?  @map("added_by")
  description  String?

  @@map("test_phones")
}

// ════════════════════════════════════════════════════════
// MULTI-TENANT INFRASTRUCTURE
// ════════════════════════════════════════════════════════

// ─── Configuración por tenant + suscripción + quotas ──────────
model TenantSettings {
  tenantId                       String   @id @map("tenant_id")
  displayName                    String   @map("display_name")
  
  // Modelo de suscripción
  numVendedoresPagados           Int      @default(0)     @map("num_vendedores_pagados")
  precioPorVendedorUsd           Decimal  @default(20.00) @map("precio_por_vendedor_usd") @db.Decimal(10,2)
  periodoMeses                   Int      @default(6)     @map("periodo_meses")
  fechaInicio                    DateTime?                @map("fecha_inicio")
  fechaFin                       DateTime?                @map("fecha_fin")
  montoTotalPagadoUsd            Decimal?                 @map("monto_total_pagado_usd") @db.Decimal(10,2)
  estadoSuscripcion              String   @default("trial") @map("estado_suscripcion")
  
  // Quota operativa de turnos IA
  turnosIncluidosPorVendedorMes  Int      @default(10000) @map("turnos_incluidos_por_vendedor_mes")
  turnosConsumidosMesActual      Int      @default(0)     @map("turnos_consumidos_mes_actual")
  mesActualInicio                DateTime @default(now()) @map("mes_actual_inicio")
  
  // API key dedicada (futuro multi-tenant real)
  geminiApiKeyEncrypted          String?  @map("gemini_api_key_encrypted")
  byokEnabled                    Boolean  @default(false) @map("byok_enabled")
  
  // Metadata
  notas                          String?  @db.Text
  
  createdAt                      DateTime @default(now()) @map("created_at")
  updatedAt                      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenant_settings")
}
